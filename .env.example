# Postgres connection string.
# Hosted (Neon/Supabase): paste the DIRECT (non-pooled) connection string so
# `prisma migrate` works; include sslmode=require.
# Local alternative: docker compose up -d, then use the URL below.
DATABASE_URL="postgresql://packscan:packscan_dev@localhost:5432/packscan"

# Auth.js — generate with: openssl rand -base64 32
AUTH_SECRET=""

# --- Carrier API credentials (Phase 2) -------------------------------------
# When a carrier's key is set, implement its provider methods in
# src/lib/carriers/rules/<carrier>.ts (verifyPickupCode + the four report*
# events). Until then every seam returns NOT_CONFIGURED and the app runs
# on local policy only. After go-live, re-queue that carrier's outbox
# history from /admin/operations ("Re-queue awaiting-credentials").
# POSTNORD_API_KEY=""
# DHL_API_KEY=""
# POSTNL_API_KEY=""
# FEDEX_API_KEY=""

# --- Retention (optional; days) ---------------------------------------------
# Used by `npm run purge:pii` (cron it in production).
# PII_RETENTION_DAYS="90"
# PREADVICE_RETENTION_DAYS="30"
