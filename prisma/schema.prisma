generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------- Enums ----------

enum Role {
  ADMIN
  CLERK
}

enum Carrier {
  DHL
  POSTNORD
  POSTNL
  FEDEX
  UNKNOWN
}

enum Direction {
  INBOUND
  OUTBOUND
}

// Superset of statuses across all flows. Which values/transitions are legal
// per direction+flow is enforced in src/lib/status.ts, not at the DB level.
enum PackageStatus {
  LOGGED
  AWAITING_PICKUP
  PICKED_UP
  PENDING_HANDOFF
  HANDED_OFF
  RETURN_PENDING
  RETURNED_TO_CARRIER
  CANCELLED
}

enum PreAdviceStatus {
  ANNOUNCED
  RECEIVED
}

enum ScanInputMethod {
  CAMERA
  HARDWARE_SCANNER
  MANUAL_ENTRY
  STATUS_ACTION
}

enum NotificationChannel {
  SMS
  EMAIL
}

enum NotificationStatus {
  WOULD_SEND
  SENT
  FAILED
}

enum NotificationTrigger {
  AWAITING_PICKUP
  PICKED_UP
}

enum IdType {
  PASSPORT
  DRIVERS_LICENSE
  NATIONAL_ID
  OTHER
}

// ---------- Models ----------

model Store {
  id        String   @id @default(cuid())
  name      String
  code      String   @unique
  address   String?
  // Staff auto-logout after this many minutes of inactivity (1-10).
  sessionIdleMinutes Int @default(10)
  // Days a parcel may await pickup before it counts as overdue for return.
  pickupDeadlineDays Int @default(7)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users      User[]
  packages   Package[]
  scanEvents ScanEvent[]
  preAdvices PreAdvice[]
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  role         Role     @default(CLERK)
  storeId      String
  store        Store    @relation(fields: [storeId], references: [id], onDelete: Restrict)
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  scanEvents ScanEvent[]

  @@index([storeId])
}

model Package {
  id             String        @id @default(cuid())
  trackingNumber String
  carrier        Carrier
  carrierManual  Boolean       @default(false)
  direction      Direction
  status         PackageStatus
  storeId        String
  store          Store         @relation(fields: [storeId], references: [id], onDelete: Restrict)

  customerName  String?
  customerPhone String?
  customerEmail String?
  notes         String?
  // Where the parcel physically sits in the store, e.g. "A3".
  shelfLocation String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  scanEvents    ScanEvent[]
  notifications Notification[]
  preAdvice     PreAdvice?

  @@unique([storeId, trackingNumber, direction])
  @@index([storeId, status])
  @@index([trackingNumber])
}

// Append-only audit log; Package.status is the current-state cache.
// Restrict (not Cascade) from Package: scan history must outlive any attempt
// to delete a package — audit rows go only if explicitly deleted first.
model ScanEvent {
  id        String  @id @default(cuid())
  packageId String
  package   Package @relation(fields: [packageId], references: [id], onDelete: Restrict)
  storeId   String
  store     Store   @relation(fields: [storeId], references: [id], onDelete: Restrict)
  userId    String
  user      User    @relation(fields: [userId], references: [id], onDelete: Restrict)

  fromStatus  PackageStatus?
  toStatus    PackageStatus
  inputMethod ScanInputMethod
  scannedAt   DateTime        @default(now())
  // Free-text context for the transition — e.g. the required cancel reason.
  note        String?
  // Driver / route / manifest reference for carrier collections
  // (HANDED_OFF, RETURNED_TO_CARRIER): who the parcel was given to.
  courierRef  String?

  verification HandoverVerification?

  @@index([packageId])
  @@index([storeId, scannedAt])
}

// Proof of handover recorded on the PICKED_UP transition: what the clerk
// verified, per the carrier's pickup policy. One per scan event.
model HandoverVerification {
  id          String    @id @default(cuid())
  scanEventId String    @unique
  scanEvent   ScanEvent @relation(fields: [scanEventId], references: [id], onDelete: Cascade)
  // The QR/pickup code the customer presented from the carrier's own app,
  // captured by scan (or typed). Audit evidence in v1; validated against the
  // carrier's API once credentials exist (CarrierProvider seam).
  presentedCode String?
  idChecked     Boolean @default(false)
  idType        IdType?
  // Set when someone other than the addressee collects (proxy pickup).
  collectorName String?
  // Manager override: handover completed without meeting the carrier policy.
  // Always paired with a reason; stands out in the audit trail by design.
  override       Boolean @default(false)
  overrideReason String?
  createdAt     DateTime @default(now())
}

// What a carrier announced as inbound for a store (the pre-advice/manifest).
// Matched by tracking number at intake: exact carrier attribution, pre-filled
// recipient details, and same-day detection of announced-but-missing parcels.
model PreAdvice {
  id             String          @id @default(cuid())
  storeId        String
  store          Store           @relation(fields: [storeId], references: [id], onDelete: Restrict)
  carrier        Carrier
  trackingNumber String
  customerName   String?
  customerPhone  String?
  customerEmail  String?
  status         PreAdviceStatus @default(ANNOUNCED)
  announcedAt    DateTime        @default(now())
  receivedAt     DateTime?
  packageId      String?         @unique
  package        Package?        @relation(fields: [packageId], references: [id], onDelete: SetNull)

  @@unique([storeId, trackingNumber])
  @@index([storeId, status])
}

model Notification {
  id        String              @id @default(cuid())
  packageId String
  package   Package             @relation(fields: [packageId], references: [id], onDelete: Cascade)
  trigger   NotificationTrigger
  channel   NotificationChannel
  recipient String
  status    NotificationStatus
  message   String
  createdAt DateTime            @default(now())

  @@index([packageId])
}
