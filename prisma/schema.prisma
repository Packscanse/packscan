generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------- Enums ----------

// ADMIN: every store (the chain/owner). MANAGER: administers their own
// store only — staff, settings, reports, overrides — never other stores,
// never ADMIN accounts. CLERK: scans.
enum Role {
  ADMIN
  MANAGER
  CLERK
}

// UI language, chosen per user on their profile.
enum Locale {
  SV
  EN
  DE
  NL
  NO
  DA
  FI
}

enum Carrier {
  DHL
  POSTNORD
  POSTNL
  FEDEX
  SCHENKER
  UNKNOWN
}

enum Direction {
  INBOUND
  OUTBOUND
}

// Superset of statuses across all flows. Which values/transitions are legal
// per direction+flow is enforced in src/lib/status.ts, not at the DB level.
enum PackageStatus {
  LOGGED
  AWAITING_PICKUP
  PICKED_UP
  PENDING_HANDOFF
  HANDED_OFF
  RETURN_PENDING
  RETURNED_TO_CARRIER
  CANCELLED
}

enum PreAdviceStatus {
  ANNOUNCED
  RECEIVED
}

enum CarrierEventType {
  ARRIVAL
  PICKED_UP
  ACCEPTED_OUTBOUND
  RETURNED
}

enum CarrierEventStatus {
  PENDING
  SENT
  NOT_CONFIGURED
  FAILED
}

enum AdminAlertType {
  // A carrier event exhausted every delivery attempt (dead-lettered FAILED).
  CARRIER_EVENT_FAILED
}

enum ScanInputMethod {
  CAMERA
  HARDWARE_SCANNER
  MANUAL_ENTRY
  STATUS_ACTION
}

enum NotificationChannel {
  SMS
  EMAIL
}

enum NotificationStatus {
  WOULD_SEND
  SENT
  FAILED
}

enum NotificationTrigger {
  AWAITING_PICKUP
  PICKED_UP
}

enum IdType {
  PASSPORT
  DRIVERS_LICENSE
  NATIONAL_ID
  OTHER
}

// ---------- Models ----------

model Store {
  id                 String   @id @default(cuid())
  name               String
  code               String   @unique
  address            String?
  // Staff auto-logout after this many minutes of inactivity (1-10).
  sessionIdleMinutes Int      @default(10)
  // Days a parcel may await pickup before it counts as overdue for return.
  pickupDeadlineDays Int      @default(7)
  // Chain branding: the store's primary color (hex, e.g. ICA red) themes
  // the app for everyone signed in to this store. Null = default theme.
  brandColor         String?
  // Store logo as a data URL (PNG/JPEG/SVG/WebP, ≤256KB) shown in the top
  // bar. DB-stored so branding needs no external file storage; move to a
  // CDN URL later without changing consumers.
  logoData           String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  users       User[]
  packages    Package[]
  scanEvents  ScanEvent[]
  preAdvices  PreAdvice[]
  adminAlerts AdminAlert[]
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  // Optional 6-digit counter PIN (bcrypt). PIN sessions can scan but never
  // reach administration — that always requires the password.
  pinHash      String?
  // 4-digit sign-in number for the device app (all-digits login: number +
  // PIN). Globally unique; assigned automatically, shown in user admin.
  loginNumber  String?  @unique
  name         String
  role         Role     @default(CLERK)
  locale       Locale   @default(EN)
  storeId      String
  store        Store    @relation(fields: [storeId], references: [id], onDelete: Restrict)
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  scanEvents     ScanEvent[]
  resolvedAlerts AdminAlert[]

  @@index([storeId])
}

model Package {
  id             String        @id @default(cuid())
  trackingNumber String
  carrier        Carrier
  carrierManual  Boolean       @default(false)
  direction      Direction
  status         PackageStatus
  storeId        String
  store          Store         @relation(fields: [storeId], references: [id], onDelete: Restrict)

  customerName  String?
  customerPhone String?
  customerEmail String?
  notes         String?
  // Where the parcel physically sits in the store, e.g. "A3".
  shelfLocation String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  scanEvents    ScanEvent[]
  notifications Notification[]
  preAdvice     PreAdvice?
  carrierEvents CarrierEventOutbox[]
  adminAlerts   AdminAlert[]

  @@unique([storeId, trackingNumber, direction])
  // Store package list: filter by store (+ optional status), newest first,
  // paginated. The composite also serves plain (storeId) and (storeId,status)
  // equality via its leftmost prefix, so it supersedes the old [storeId,status].
  @@index([storeId, status, updatedAt(sort: Desc)])
  @@index([storeId, updatedAt(sort: Desc)])
  @@index([trackingNumber])
  // Chain-wide shelf aging aggregates filter on status alone.
  @@index([status])
  // Date-range report aggregates (received today / last 30 days), chain-wide
  // and per store — without these each dashboard load seq-scans all history.
  @@index([createdAt])
  @@index([storeId, createdAt])
}

// Append-only audit log; Package.status is the current-state cache.
// Restrict (not Cascade) from Package: scan history must outlive any attempt
// to delete a package — audit rows go only if explicitly deleted first.
model ScanEvent {
  id        String  @id @default(cuid())
  packageId String
  package   Package @relation(fields: [packageId], references: [id], onDelete: Restrict)
  storeId   String
  store     Store   @relation(fields: [storeId], references: [id], onDelete: Restrict)
  userId    String
  user      User    @relation(fields: [userId], references: [id], onDelete: Restrict)

  fromStatus  PackageStatus?
  toStatus    PackageStatus
  inputMethod ScanInputMethod
  scannedAt   DateTime        @default(now())
  // Free-text context for the transition — e.g. the required cancel reason.
  note        String?
  // Driver / route / manifest reference for carrier collections
  // (HANDED_OFF, RETURNED_TO_CARRIER): who the parcel was given to.
  courierRef  String?

  verification HandoverVerification?

  @@index([packageId])
  @@index([storeId, scannedAt])
  // Chain-wide period reports (dwell, hour profile, settlement) range on time alone.
  @@index([scannedAt])
}

// Proof of handover recorded on the PICKED_UP transition: what the clerk
// verified, per the carrier's pickup policy. One per scan event.
model HandoverVerification {
  id             String    @id @default(cuid())
  scanEventId    String    @unique
  scanEvent      ScanEvent @relation(fields: [scanEventId], references: [id], onDelete: Cascade)
  // The QR/pickup code the customer presented from the carrier's own app,
  // captured by scan (or typed). Audit evidence in v1; validated against the
  // carrier's API once credentials exist (CarrierProvider seam).
  presentedCode  String?
  // True once the carrier's API confirmed the presented code (Phase 2);
  // false means captured-as-evidence only.
  codeValidated  Boolean   @default(false)
  idChecked      Boolean   @default(false)
  idType         IdType?
  // Set when someone other than the addressee collects (proxy pickup).
  collectorName  String?
  // Proxy pickups verify both documents at the counter: idChecked above is
  // the addressee's ID, these are the collector's own. Only the fact and the
  // document type are stored — never the documents' contents.
  collectorIdChecked Boolean @default(false)
  collectorIdType    IdType?
  // Manager override: handover completed without meeting the carrier policy.
  // Always paired with a reason; stands out in the audit trail by design.
  override       Boolean   @default(false)
  overrideReason String?
  createdAt      DateTime  @default(now())
}

// At-least-once delivery queue for carrier lifecycle events. A row is
// written in the same transaction as the scan event that caused it; the
// dispatcher (immediate attempt + cron retry) owns status/attempts. Rows
// stay as a delivery log; NOT_CONFIGURED rows can be re-queued once a
// carrier's API credentials arrive.
model CarrierEventOutbox {
  id            String             @id @default(cuid())
  packageId     String
  package       Package            @relation(fields: [packageId], references: [id], onDelete: Cascade)
  carrier       Carrier
  eventType     CarrierEventType
  // Event-specific payload, e.g. the proof-of-delivery summary for PICKED_UP.
  payload       Json?
  status        CarrierEventStatus @default(PENDING)
  attempts      Int                @default(0)
  lastError     String?
  nextAttemptAt DateTime           @default(now())
  createdAt     DateTime           @default(now())
  sentAt        DateTime?

  @@index([status, nextAttemptAt])
  @@index([packageId])
}

// Something went wrong that an admin must see — today raised only when a
// carrier event dead-letters after MAX_ATTEMPTS. Shown on the admin overview
// until resolved by hand; requeueing the outbox is the usual fix.
model AdminAlert {
  id        String         @id @default(cuid())
  type      AdminAlertType
  storeId   String
  store     Store          @relation(fields: [storeId], references: [id], onDelete: Cascade)
  // Nullable so alert history outlives purged/deleted packages.
  packageId String?
  package   Package?       @relation(fields: [packageId], references: [id], onDelete: SetNull)
  message   String
  createdAt DateTime       @default(now())

  resolvedAt   DateTime?
  resolvedById String?
  resolvedBy   User?     @relation(fields: [resolvedById], references: [id], onDelete: SetNull)

  // Overview lists open alerts (resolvedAt IS NULL) newest first.
  @@index([resolvedAt, createdAt])
  @@index([storeId])
}

// What a carrier announced as inbound for a store (the pre-advice/manifest).
// Matched by tracking number at intake: exact carrier attribution, pre-filled
// recipient details, and same-day detection of announced-but-missing parcels.
model PreAdvice {
  id             String          @id @default(cuid())
  storeId        String
  store          Store           @relation(fields: [storeId], references: [id], onDelete: Restrict)
  carrier        Carrier
  trackingNumber String
  customerName   String?
  customerPhone  String?
  customerEmail  String?
  status         PreAdviceStatus @default(ANNOUNCED)
  announcedAt    DateTime        @default(now())
  receivedAt     DateTime?
  packageId      String?         @unique
  package        Package?        @relation(fields: [packageId], references: [id], onDelete: SetNull)

  @@unique([storeId, trackingNumber])
  @@index([storeId, status])
}

model Notification {
  id        String              @id @default(cuid())
  packageId String
  package   Package             @relation(fields: [packageId], references: [id], onDelete: Cascade)
  trigger   NotificationTrigger
  channel   NotificationChannel
  recipient String
  status    NotificationStatus
  message   String
  createdAt DateTime            @default(now())

  @@index([packageId])
}
