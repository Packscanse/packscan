{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "packscan-dev",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "port": 3000
    },
    {
      "name": "packscan-dev-alt",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev", "--", "-p", "3100"],
      "port": 3100
    },
    {
      "name": "packscan-dev-phone",
      "runtimeExecutable": "npm",
      "runtimeArgs": [
        "run", "dev", "--",
        "--experimental-https",
        "--experimental-https-key", "./certificates/lan-key.pem",
        "--experimental-https-cert", "./certificates/lan-cert.pem",
        "-H", "0.0.0.0",
        "-p", "3200"
      ],
      "port": 3200
    }
  ]
}
